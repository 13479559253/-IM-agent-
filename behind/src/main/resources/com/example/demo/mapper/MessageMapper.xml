<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.MessageMapper">
    <insert id="addMessage" keyProperty="id" useGeneratedKeys="true">
        insert into message (sender_id,conversation_id,content,send_time) values (#{senderId},#{conversationId},#{content},#{sendTime});
    </insert>
    <select id="getMessage">
        select content,sender_id,send_time from message where conversation_id = #{conversationId}
    </select>
    <delete id="deleteMessage">
        delete from message where conversation_id = #{conversationId}
    </delete>
</mapper>